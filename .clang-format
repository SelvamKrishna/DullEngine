---
Language: Cpp
BasedOnStyle: LLVM

# Access modifier formatting
AccessModifierOffset: -4  # This removes indentation completely
# (Negative value aligns with class scope)

# Core formatting
ColumnLimit: 110
IndentWidth: 4
UseTab: Never

# Parentheses and functions
AllowAllParametersOfDeclarationOnNextLine: false
AllowAllArgumentsOnNextLine: false
BinPackParameters: false
BinPackArguments: false
PenaltyBreakBeforeFirstCallParameter: 100

# Brace wrapping
BraceWrapping:
  AfterFunction: true
  AfterClass: true
  AfterControlStatement: Never

# Spacing
SpaceBeforeParens: ControlStatements
SpaceInEmptyParentheses: false

...

# (Keep all your other existing settings)